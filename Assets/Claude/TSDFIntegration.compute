// TSDF Integration - LaserTag style with Meta SDK depth
#pragma kernel Clear
#pragma kernel Integrate

// Volume
uniform uint3 volumeSize;
uniform float metersPerVoxel;
RWTexture3D<half> volume; // Simple half format like LaserTag
StructuredBuffer<float3> frustumVolume; // View-space positions

// Meta SDK depth texture
Texture2DArray<float> _EnvironmentDepthTexture;
SamplerState sampler_EnvironmentDepthTexture;

// Camera matrices (only need one eye for now)
float4x4 _ViewMatrix;
float4x4 _ProjMatrix;
float4x4 _InvViewMatrix;
float4x4 _InvProjMatrix;

// Parameters
float _TruncationDistance;
int _MaxWeight;
float2 _DepthRange;

// Player culling
int _NumPlayers;
float4 _PlayerPositions[16];
float _PlayerRadius;
float _PlayerHeight;

#define PLAYER_TOP 0.2 
#define PLAYER_BOTTOM 1.7
#define MIN_DOT 0.3

// === COORDINATE CONVERSION (LaserTag style) ===

float3 voxelToWorld(uint3 indices)
{
    float3 pos = indices;
    pos += 0.5;
    pos -= volumeSize / 2.0;
    pos *= metersPerVoxel;
    return pos;
}

uint3 worldToVoxel(float3 pos)
{
    pos /= metersPerVoxel;
    pos += volumeSize / 2.0;
    uint3 id = uint3(pos);
    id = clamp(id, uint3(0, 0, 0), volumeSize - 1);
    return id;
}

// === CLEAR KERNEL ===

[numthreads(4, 4, 4)]
void Clear(uint3 id : SV_DispatchThreadID)
{
    volume[id] = 1.0; // Max distance = empty
}

// === INTEGRATE KERNEL ===

[numthreads(64, 1, 1)]
void Integrate(uint i : SV_DispatchThreadID)
{
    // Get voxel position in VIEW SPACE from frustum buffer
    float3 vLocalPos = frustumVolume[i];
    
    // Transform to WORLD SPACE
    float3 vWorldPos = mul(_InvViewMatrix, float4(vLocalPos, 1)).xyz;
    uint3 voxelIdx = worldToVoxel(vWorldPos);
    
    // Get eye position
    float3 eyePos = _InvViewMatrix._m03_m13_m23;
    float3 voxPos = voxelToWorld(voxelIdx);
    
    // Project voxel to screen (HCS = Homogeneous Clip Space)
    float4 voxHCS = mul(_ProjMatrix, mul(_ViewMatrix, float4(voxPos, 1)));
    float3 voxNDC = (voxHCS.xyz / voxHCS.w) * 0.5 + 0.5;
    
    // Bounds check
    if (any(voxNDC.xy < 0.0) || any(voxNDC.xy > 1.0))
        return;
    
    // Sample depth from Meta SDK (distance in meters!)
    float depth0 = _EnvironmentDepthTexture.SampleLevel(sampler_EnvironmentDepthTexture, float3(voxNDC.xy, 0), 0);
    float depth1 = _EnvironmentDepthTexture.SampleLevel(sampler_EnvironmentDepthTexture, float3(voxNDC.xy, 1), 0);
    
    // Use minimum valid depth
    float surfaceDepth = min(depth0, depth1);
    
    if (surfaceDepth <= 0.01 || surfaceDepth > _DepthRange.y)
        return;
    
    // Calculate distances
    float voxEyeDist = distance(voxPos, eyePos);
    
    // Meta depth gives ACTUAL distance, not NDC!
    float depthEyeDist = surfaceDepth;
    
    // Signed distance
    float sDist = depthEyeDist - voxEyeDist;
    
    // Simple normal estimation (could be improved)
    float3 eyeToVox = normalize(voxPos - eyePos);
    float normDot = 1.0; // Simplified - assume good viewing angle
    
    // Apply normal weight
    sDist *= saturate(normDot);
    
    // Normalize by voxel size
    half sDistNorm = sDist / metersPerVoxel;
    sDistNorm = clamp(sDistNorm, -1.0, 1.0);
    
    // Player culling
    bool inPlayer = false;
    for (int j = 0; j < _NumPlayers; j++)
    {
        float3 playerPos = _PlayerPositions[j].xyz;
        
        if (distance(vWorldPos.xz, playerPos.xz) < _PlayerRadius &&
            vWorldPos.y < playerPos.y + PLAYER_TOP &&
            vWorldPos.y > playerPos.y - PLAYER_BOTTOM)
        {
            inPlayer = true;
            break;
        }
    }
    
    // Write to volume (simple overwrite like LaserTag)
    if (sDistNorm > -1.0 && !inPlayer && normDot > MIN_DOT)
    {
        volume[voxelIdx] = sDistNorm;
    }
}