// Converts TSDF 3D RenderTexture (R16_SFloat/half) to flat float buffer for marching cubes
#pragma kernel ConvertTSDFToVoxels

// Input: TSDF volume (single channel half/float16)
Texture3D<half> _TSDFVolume;
SamplerState sampler_TSDFVolume;

// Output: Flat voxel buffer (floats for marching cubes)
RWStructuredBuffer<float> _VoxelBuffer;

// Parameters
uint3 _Resolution;

[numthreads(8, 8, 8)]
void ConvertTSDFToVoxels(uint3 id : SV_DispatchThreadID)
{
    if (any(id >= _Resolution))
        return;
    
    // Sample TSDF value at this voxel
    float3 uvw = (float3(id) + 0.5) / float3(_Resolution);
    half tsdfValue = _TSDFVolume.SampleLevel(sampler_TSDFVolume, uvw, 0);
    
    // Convert half to float and write to flat buffer
    // Buffer layout: x + width * (y + height * z)
    uint index = id.x + _Resolution.x * (id.y + _Resolution.y * id.z);
    _VoxelBuffer[index] = float(tsdfValue);
}